---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found">
  <section class="mx-auto max-w-2xl px-4 py-24 text-center sm:px-6">
    <h1 class="text-ink text-4xl font-bold">404</h1>
    <p class="text-ink-muted mt-4 text-lg">
      The page you are looking for does not exist.
    </p>
    <a
      href="/"
      class="text-brand-500 hover:text-brand-600 mt-8 inline-flex text-sm font-semibold"
    >
      Back to home
    </a>
  </section>
</BaseLayout>
