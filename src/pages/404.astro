---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <section class="mx-auto max-w-2xl px-4 py-24 text-center sm:px-6">
    <h1 class="text-4xl font-bold text-ink">404</h1>
    <p class="mt-4 text-lg text-ink-muted">The page you are looking for does not exist.</p>
    <a href="/" class="mt-8 inline-flex text-sm font-semibold text-brand-500 hover:text-brand-600">
      Back to home
    </a>
  </section>
</BaseLayout>
