---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/astro/Hero.astro';
import ValueCards from '../components/astro/ValueCards.astro';
import CommunityCallout from '../components/astro/CommunityCallout.astro';
import { getEnv, getSiteConfig } from '../lib/env';

const site = getSiteConfig();
const env = getEnv();
---

<BaseLayout>
  <Hero
    name={site.name}
    tagline={site.tagline}
    description={site.description}
    discordUrl={env.discordInviteUrl}
    memberCount={site.memberCount}
  />
  <ValueCards />
  <CommunityCallout />
</BaseLayout>
