---
interface Props {
  title: string;
  url: string;
  description?: string;
  category: string;
  featured?: boolean;
}

const { title, url, description, category, featured = false } = Astro.props;
---

<article class="rounded-xl border border-border bg-surface-elevated p-5 transition-colors hover:bg-surface-hover">
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-lg font-semibold text-ink">
      <a href={url} target="_blank" rel="noopener noreferrer" class="hover:text-brand-500">
        {title}
      </a>
    </h3>
    {featured && (
      <span class="shrink-0 rounded-full bg-admin/20 px-2 py-0.5 text-xs font-medium text-admin">
        Featured
      </span>
    )}
  </div>
  {description && <p class="mt-2 text-sm text-ink-muted">{description}</p>}
  <p class="mt-3 text-xs font-medium uppercase tracking-wide text-brand-500">{category}</p>
</article>
