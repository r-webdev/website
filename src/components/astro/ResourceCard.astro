---
interface Props {
  title: string;
  url: string;
  description?: string;
  category: string;
  featured?: boolean;
}

const { title, url, description, category, featured = false } = Astro.props;
---

<article
  class="border-border bg-surface-elevated hover:bg-surface-hover rounded-xl border p-5 transition-colors"
>
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-ink text-lg font-semibold">
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-brand-500"
      >
        {title}
      </a>
    </h3>
    {
      featured && (
        <span class="bg-admin/20 text-admin shrink-0 rounded-full px-2 py-0.5 text-xs font-medium">
          Featured
        </span>
      )
    }
  </div>
  {description && <p class="text-ink-muted mt-2 text-sm">{description}</p>}
  <p class="text-brand-500 mt-3 text-xs font-medium tracking-wide uppercase">
    {category}
  </p>
</article>
