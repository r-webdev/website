---
import DiscordCTA from './DiscordCTA.astro';
import ServerLogo from './ServerLogo.astro';
import MobileNav from '../react/MobileNav';
import { navLinks } from '../../lib/nav';

interface Props {
  siteName: string;
  discordUrl: string;
}

const { siteName, discordUrl } = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-border bg-surface-elevated/95 backdrop-blur">
  <div class="h-1 w-full pride-border" aria-hidden="true"></div>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="flex items-center gap-2.5 text-lg font-bold text-ink hover:text-brand-500">
      <ServerLogo size="sm" />
      <span>{siteName}</span>
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Main navigation">
      {
        navLinks.map((link) => (
          <a href={link.href} class="text-sm font-medium text-ink-muted hover:text-brand-500">
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden md:block">
      <DiscordCTA href={discordUrl} />
    </div>

    <MobileNav client:load navLinks={navLinks} discordUrl={discordUrl} />
  </div>
</header>
