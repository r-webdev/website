---
import DiscordCTA from "./DiscordCTA.astro";
import ServerLogo from "./ServerLogo.astro";

interface Props {
  name: string;
  tagline: string;
  description: string;
  discordUrl: string;
  memberCount?: string;
}

const { name, tagline, description, discordUrl, memberCount } = Astro.props;

const techPills = ["HTML", "CSS", "JavaScript", "Design", "Accessibility"];
---

<section
  class="relative overflow-hidden border-b border-border bg-gradient-to-b from-surface-elevated to-surface py-16 sm:py-24"
>
  <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
    <div class="flex justify-center">
      <ServerLogo size="lg" />
    </div>
    <p class="mt-6 text-sm font-semibold uppercase tracking-wider text-admin">
      Welcome to
    </p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-ink sm:text-5xl">
      {name}
    </h1>
    <p class="mt-4 text-lg text-ink-muted sm:text-xl">{tagline}</p>
    {
      memberCount && (
        <p class="mt-3 text-sm font-medium text-admin">
          {memberCount} members and growing
        </p>
      )
    }
    <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-ink-muted">
      {description}
    </p>
    <div
      class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row"
    >
      <DiscordCTA href={discordUrl} />
      <a
        href="/learning"
        class="inline-flex items-center justify-center rounded-lg border border-admin px-5 py-2.5 text-sm font-semibold text-admin hover:bg-admin/15 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-admin"
      >
        Browse resources
      </a>
    </div>
    <ul
      class="mt-10 flex flex-wrap items-center justify-center gap-3 text-xs font-medium text-ink-muted"
    >
      {
        techPills.map((pill) => (
          <li class="rounded-full border border-border bg-surface-elevated px-3 py-1">
            {pill}
          </li>
        ))
      }
    </ul>
  </div>
</section>
