---
import DiscordCTA from "./DiscordCTA.astro";

interface Props {
  siteName: string;
  discordUrl: string;
  githubUrl?: string;
}

const { siteName, discordUrl, githubUrl } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-border bg-surface-elevated border-t">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-8 sm:px-6 md:flex-row md:items-center md:justify-between"
  >
    <div>
      <p class="text-ink font-semibold">{siteName}</p>
      <p class="text-ink-muted mt-1 text-sm">Hosted on Cloudflare Pages</p>
    </div>
    <nav class="flex flex-wrap items-center gap-4" aria-label="Social links">
      <DiscordCTA href={discordUrl} variant="secondary" />
      {
        githubUrl && (
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-ink-muted hover:text-brand-500 text-sm font-medium"
          >
            GitHub
          </a>
        )
      }
    </nav>
    <p class="text-ink-muted text-sm">&copy; {year} {siteName}</p>
  </div>
</footer>
