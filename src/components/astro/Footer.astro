---
import DiscordCTA from './DiscordCTA.astro';

interface Props {
  siteName: string;
  discordUrl: string;
  githubUrl?: string;
}

const { siteName, discordUrl, githubUrl } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-surface-elevated">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-8 sm:px-6 md:flex-row md:items-center md:justify-between">
    <div>
      <p class="font-semibold text-ink">{siteName}</p>
      <p class="mt-1 text-sm text-ink-muted">Hosted on Cloudflare Pages</p>
    </div>
    <nav class="flex flex-wrap items-center gap-4" aria-label="Social links">
      <DiscordCTA href={discordUrl} variant="secondary" />
      {
        githubUrl && (
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-medium text-ink-muted hover:text-brand-500"
          >
            GitHub
          </a>
        )
      }
    </nav>
    <p class="text-sm text-ink-muted">&copy; {year} {siteName}</p>
  </div>
</footer>
