---
import DiscordCTA from "@components/discord/DiscordCTA.astro";
import ServerLogo from "@components/icons/ServerLogo.astro";
import { navLinks } from "@lib/nav";
import MobileNav from "./MobileNav.astro";

interface Props {
  siteName: string;
  discordUrl: string;
}

const { siteName, discordUrl } = Astro.props;
---

<header
  class="border-border bg-surface-elevated/95 sticky top-0 z-50 border-b backdrop-blur"
>
  <div class="pride-border h-1 w-full" aria-hidden="true"></div>
  <div
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6"
  >
    <a
      href="/"
      class="text-ink hover:text-brand-500 flex items-center gap-2.5 text-lg font-bold"
    >
      <ServerLogo size="sm" />
      <span>{siteName}</span>
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Main navigation">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-ink-muted hover:text-brand-500 text-sm font-medium"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden md:block">
      <DiscordCTA href={discordUrl} />
    </div>

    <MobileNav navLinks={navLinks} discordUrl={discordUrl} />
  </div>
</header>
