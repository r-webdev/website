---
interface Props {
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { size = "md", class: className = "" } = Astro.props;

const sizes = {
  sm: "h-6 w-6",
  md: "h-12 w-12",
  lg: "h-20 w-20",
};
---

<img
  src="/logo.png"
  alt=""
  class:list={[sizes[size], className]}
  width="64"
  height="64"
  aria-hidden="true"
/>
